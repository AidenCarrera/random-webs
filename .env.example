# Public origin used for canonical URLs, sitemap entries, Open Graph metadata,
# robots.txt, and sitemap.xml. Use the origin only: no trailing path, query, or hash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production example:
# NEXT_PUBLIC_SITE_URL=https://random-webs.vercel.app

# Optional comma-separated origins allowed to access the development server.
# ALLOWED_DEV_ORIGINS=local-origin.dev,*.local-origin.dev
